---
/**
 * Ana Sayfa `/`
 * Hero alanı, öne çıkan özellikler, kısa sunucu tanıtımı ve Discord CTA.
 */
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionTitle from '../components/SectionTitle.astro';
import FeatureCard from '../components/FeatureCard.astro';
import BlogCard from '../components/BlogCard.astro';
import DiscordCTA from '../components/DiscordCTA.astro';
import Icon from '../components/Icon.astro';
import { features } from '../data/features';
import { siteConfig } from '../data/siteConfig';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = (p: string) => `${base}${p}` || '/';

// Son 3 yayınlanmış blog yazısını al
const posts = (await getCollection('blog', ({ data }) => data.published === true))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title={siteConfig.siteName} description={siteConfig.description}>
  <HeroSection />

  <!-- Kısa tanıtım -->
  <section class="section">
    <div class="container intro-grid">
      <div class="reveal">
        <SectionTitle
          eyebrow="Cephe Hattı"
          title="Tarihin Eşiğindeki Avrupa"
          subtitle="Hearts Of Steel I, savaşın patlak vermek üzere olduğu 1936 Avrupa’sını Minecraft’a taşır. Bir ulus kur, halkını yönet ve kıtanın kaderini belirle."
        />
        <ul class="intro-list">
          <li><Icon name="general" size={20} /> Towny tabanlı şehir ve ulus yönetimi</li>
          <li><Icon name="diplomacy" size={20} /> Derin diplomasi ve ittifak mekanikleri</li>
          <li><Icon name="tank" size={20} /> Dönemin tank, uçak ve silahları</li>
          <li><Icon name="roleplay" size={20} /> Rolplay destekli savaş deneyimi</li>
        </ul>
        <a href={path('/server')} class="btn btn--ghost intro-cta">
          Sunucuyu Keşfet <Icon name="arrow-right" size={16} />
        </a>
      </div>

      <div class="intro-panel reveal" aria-hidden="true">
        <div class="panel-header">
          <span class="panel-dot"></span>
          <span>OPERASYON DURUMU</span>
        </div>
        <div class="panel-rows">
          <div><span>Harita</span><strong>1936 Avrupa</strong></div>
          <div><span>Sürüm</span><strong>MC {siteConfig.minecraftVersion}</strong></div>
          <div><span>Altyapı</span><strong>{siteConfig.serverSoftware}</strong></div>
          <div><span>Mod Sayısı</span><strong>50+</strong></div>
          <div><span>Mod Tipi</span><strong>Towny + Savaş</strong></div>
        </div>
        <div class="panel-footer">
          <span class="status-live"></span> Sezon 1 — Kuruluş Dönemi
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="section">
    <div class="container">
      <SectionTitle
        eyebrow="Sunucu Özellikleri"
        title="Sahada Seni Bekleyenler"
        subtitle="Her detay, sürükleyici ve dengeli bir savaş deneyimi için tasarlandı."
        align="center"
      />
      <div class="features-grid">
        {features.map((f) => <FeatureCard icon={f.icon} title={f.title} description={f.description} />)}
      </div>
    </div>
  </section>

  <!-- Son blog yazıları -->
  {
    posts.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="blog-head">
            <SectionTitle
              eyebrow="Cepheden Haberler"
              title="Son Blog Yazıları"
            />
            <a href={path('/blog')} class="btn btn--ghost">
              Tümünü Gör <Icon name="arrow-right" size={16} />
            </a>
          </div>
          <div class="home-blog-grid">
            {posts.map((p) => (
              <BlogCard
                slug={p.slug}
                title={p.data.title}
                description={p.data.description}
                date={p.data.date}
                author={p.data.author}
                category={p.data.category}
                cover={p.data.cover}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <DiscordCTA />
</Layout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .intro-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0.5rem 0 1.75rem;
  }
  .intro-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--c-text);
  }
  .intro-list :global(svg) {
    color: var(--c-gold);
    flex-shrink: 0;
  }
  .intro-cta {
    margin-top: 0.5rem;
  }

  /* Sağdaki "operasyon durumu" paneli */
  .intro-panel {
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
    background:
      repeating-linear-gradient(45deg, rgba(255,255,255,0.015) 0 1px, transparent 1px 10px),
      var(--surface-2);
    padding: 1.5rem;
  }
  .panel-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 2px;
    color: var(--c-gold);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--c-border);
  }
  .panel-dot {
    width: 8px;
    height: 8px;
    background: var(--c-gold);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--c-gold);
  }
  .panel-rows {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-block: 1.25rem;
  }
  .panel-rows div {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
  }
  .panel-rows span {
    color: var(--c-text-faint);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 1px;
  }
  .panel-rows strong {
    font-family: var(--font-display);
    letter-spacing: 0.5px;
  }
  .panel-footer {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border);
    font-size: 0.85rem;
    color: var(--c-text-dim);
  }
  .status-live {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 10px #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .blog-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .home-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 980px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .home-blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 820px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 600px) {
    .features-grid,
    .home-blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
