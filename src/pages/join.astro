---
/**
 * Nasıl Katılırım? `/join`
 * Sunucuya bağlanmak için adım adım rehber + hızlı bilgi kartları.
 * Discord linki, modpack linki ve IP tamamen siteConfig'ten gelir.
 */
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DiscordCTA from '../components/DiscordCTA.astro';
import { siteConfig } from '../data/siteConfig';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = (p: string) => `${base}${p}` || '/';

const steps = [
  {
    n: 1,
    title: 'Discord’a Katıl',
    body: 'Tüm güncel linkler, duyurular ve destek Discord üzerinden sağlanır. İlk adım topluluğa katılmak.',
    icon: 'general',
    cta: { label: "Discord'a Katıl", url: siteConfig.discordUrl, external: true },
  },
  {
    n: 2,
    title: 'Kuralları Oku',
    body: 'Sahaya çıkmadan önce sunucu kurallarını incele. Adil ve düzenli bir oyun deneyimi herkesin sorumluluğu.',
    icon: 'book',
    cta: { label: 'Kuralları Gör', url: path('/rules'), external: false },
  },
  {
    n: 3,
    title: 'Modpack’i İndir ve Kur',
    body: 'Resmî modpack’i indir ve Forge 1.20.1 ile kur. Adım adım kurulum rehberi modpack sayfasında.',
    icon: 'download',
    cta: { label: 'Modpack Sayfası', url: path('/modpack'), external: false },
  },
  {
    n: 4,
    title: 'Sunucuya Giriş Yap',
    body: 'Çoklu oyuncu menüsünden sunucu adresini ekle ve giriş yap. 1936 Avrupa’sı seni bekliyor.',
    icon: 'flag',
    cta: null,
  },
];
---

<Layout
  title="Nasıl Katılırım?"
  description="Hearts Of Steel I sunucusuna nasıl katılınır? Minecraft 1.20.1, Mohist altyapısı ve adım adım modpack kurulum rehberi."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow reveal">Sefere Hazırlık</span>
      <h1 class="reveal">Nasıl Katılırım?</h1>
      <p class="reveal text-dim">
        Dört basit adımda cepheye katıl. Aşağıdaki sürüm bilgilerine dikkat et.
      </p>
    </div>
  </section>

  <!-- Hızlı bilgi kartları -->
  <section class="section info-section">
    <div class="container">
      <div class="info-cards">
        <div class="info-card reveal">
          <span class="info-label">Minecraft Sürümü</span>
          <strong>{siteConfig.minecraftVersion}</strong>
        </div>
        <div class="info-card reveal">
          <span class="info-label">Altyapı</span>
          <strong>{siteConfig.serverSoftware}</strong>
        </div>
        <button class="info-card info-card--ip reveal" id="joinCopyIp" data-ip={siteConfig.serverIp} type="button">
          <span class="info-label">Sunucu IP <em id="joinCopyState">(kopyalamak için tıkla)</em></span>
          <strong>{siteConfig.serverIp}</strong>
        </button>
      </div>
    </div>
  </section>

  <!-- Adımlar -->
  <section class="section">
    <div class="container">
      <div class="steps">
        {
          steps.map((s) => (
            <article class="step reveal">
              <div class="step-num">{String(s.n).padStart(2, '0')}</div>
              <div class="step-icon"><Icon name={s.icon} size={24} /></div>
              <div class="step-content">
                <h2>{s.title}</h2>
                <p class="text-dim">{s.body}</p>
                {s.cta && (
                  <a
                    href={s.cta.url}
                    class:list={['btn', s.n === 1 ? 'btn--discord' : 'btn--ghost']}
                    target={s.cta.external ? '_blank' : undefined}
                    rel={s.cta.external ? 'noopener' : undefined}
                  >
                    {s.cta.label}
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <DiscordCTA
    title="Takıldığın Bir Yer mi Var?"
    text="Kurulum veya bağlantı sorunlarında Discord’daki destek kanalından yardım alabilirsin."
  />
</Layout>

<style>
  .page-hero {
    padding-block: clamp(3rem, 8vw, 5rem) 1rem;
    text-align: center;
    border-bottom: 1px solid var(--c-border);
    background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(212,175,55,0.08), transparent 60%);
  }
  .page-hero h1 {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    text-transform: uppercase;
    margin-top: 0.75rem;
  }
  .page-hero p {
    margin-top: 0.85rem;
    max-width: 52ch;
    margin-inline: auto;
  }

  .info-section {
    padding-bottom: 0;
  }
  .info-cards {
    display: grid;
    grid-template-columns: 1fr 1fr 1.6fr;
    gap: 1rem;
  }
  .info-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--surface-1);
    text-align: left;
    font: inherit;
    color: inherit;
  }
  .info-card--ip {
    cursor: pointer;
    border-style: dashed;
    border-color: var(--c-line);
    transition: border-color var(--t-fast), background var(--t-fast);
  }
  .info-card--ip:hover {
    border-color: var(--c-gold);
    background: rgba(212, 175, 55, 0.06);
  }
  .info-label {
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--c-text-faint);
  }
  .info-label em {
    font-style: normal;
    text-transform: none;
    letter-spacing: 0;
  }
  .info-card strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--c-gold);
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 820px;
    margin-inline: auto;
  }
  .step {
    position: relative;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: start;
    gap: 1.25rem;
    padding: 1.6rem;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--surface-1);
    transition: transform var(--t-fast), border-color var(--t-fast);
  }
  .step:hover {
    transform: translateX(4px);
    border-color: var(--c-line);
  }
  .step-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: rgba(212, 175, 55, 0.35);
    line-height: 1;
  }
  .step-icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: var(--radius);
    color: var(--c-gold);
    background: rgba(212, 175, 55, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.2);
  }
  .step-content h2 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
  }
  .step-content p {
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  @media (max-width: 680px) {
    .info-cards {
      grid-template-columns: 1fr;
    }
    .step {
      grid-template-columns: auto 1fr;
    }
    .step-num {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('joinCopyIp');
  const state = document.getElementById('joinCopyState');
  btn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.getAttribute('data-ip') || '');
      if (state) {
        state.textContent = '(kopyalandı ✓)';
        setTimeout(() => (state.textContent = '(kopyalamak için tıkla)'), 1800);
      }
    } catch {}
  });
</script>
