---
/**
 * Blog yazısı kartı.
 * Kapak görseli (yoksa şık gradient fallback), kategori rozeti, başlık,
 * açıklama, tarih ve yazar bilgisini gösterir.
 */
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  author: string;
  category: string;
  cover?: string;
}
const { slug, title, description, date, author, category, cover } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${base}/blog/${slug}`;
const coverSrc = cover ? `${base}${cover}` : null;

const formattedDate = new Intl.DateTimeFormat('tr-TR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(date);
---

<article class="blog-card reveal">
  <a href={href} class="blog-card-link" aria-label={title}>
    <div class="blog-cover">
      {
        coverSrc ? (
          <img src={coverSrc} alt={title} loading="lazy" width="600" height="338" />
        ) : (
          <div class="blog-cover-fallback">
            <span>{category}</span>
          </div>
        )
      }
      <span class="blog-category">{category}</span>
    </div>
    <div class="blog-body">
      <h3>{title}</h3>
      <p class="text-dim">{description}</p>
      <div class="blog-meta">
        <span>{author}</span>
        <span class="dot">•</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--surface-1);
    overflow: hidden;
    transition: transform var(--t), border-color var(--t), box-shadow var(--t);
  }
  .blog-card:hover {
    transform: translateY(-5px);
    border-color: var(--c-line);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.4);
  }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--c-navy-800);
  }
  .blog-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--t);
  }
  .blog-card:hover .blog-cover img {
    transform: scale(1.06);
  }
  .blog-cover-fallback {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 30% 20%, rgba(212, 175, 55, 0.18), transparent 50%),
      repeating-linear-gradient(45deg, rgba(255,255,255,0.02) 0 2px, transparent 2px 12px),
      linear-gradient(135deg, var(--c-navy-700), var(--c-charcoal));
  }
  .blog-cover-fallback span {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--c-text-faint);
    font-size: 0.9rem;
  }
  .blog-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #1a1407;
    background: linear-gradient(180deg, var(--c-gold-soft), var(--c-amber));
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius);
  }

  .blog-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.25rem;
    flex: 1;
  }
  .blog-body h3 {
    font-size: 1.18rem;
    line-height: 1.25;
    transition: color var(--t-fast);
  }
  .blog-card:hover .blog-body h3 {
    color: var(--c-gold);
  }
  .blog-body p {
    font-size: 0.9rem;
    line-height: 1.55;
    flex: 1;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--c-text-faint);
    padding-top: 0.5rem;
    border-top: 1px solid var(--c-border);
  }
  .blog-meta .dot {
    opacity: 0.5;
  }
</style>
