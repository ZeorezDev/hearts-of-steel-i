---
/**
 * Sosyal medya ikonları (inline SVG).
 * Harici ikon kütüphanesi yüklememek için sade SVG'ler kullanılır.
 */
interface Props {
  name: 'discord' | 'youtube' | 'twitter' | 'instagram' | 'tiktok';
}
const { name } = Astro.props;
---

{
  name === 'discord' && (
    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
      <path d="M20.3 4.4A19.8 19.8 0 0 0 15.4 3l-.2.4a18.3 18.3 0 0 1 4.3 1.4A18.1 18.1 0 0 0 5 4.8 18.8 18.8 0 0 1 9.2 3.4L9 3a19.8 19.8 0 0 0-5 1.4C1.3 8.3.6 12 .9 15.7A20 20 0 0 0 6.9 18l.5-.7a13 13 0 0 1-2.1-1l.5-.4a14 14 0 0 0 12.2 0l.5.4a13 13 0 0 1-2.1 1l.5.7a20 20 0 0 0 6-2.3c.4-4.6-.7-8.3-2.6-11.3ZM8.3 13.5c-1 0-1.9-.9-1.9-2.1 0-1.1.8-2 1.9-2s1.9 1 1.9 2.1c0 1.2-.8 2-1.9 2Zm7.4 0c-1 0-1.9-.9-1.9-2.1 0-1.1.8-2 1.9-2s1.9 1 1.9 2.1c0 1.2-.8 2-1.9 2Z" />
    </svg>
  )
}
{
  name === 'youtube' && (
    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
      <path d="M23 7.5a3 3 0 0 0-2.1-2.1C19 5 12 5 12 5s-7 0-8.9.4A3 3 0 0 0 1 7.5 31 31 0 0 0 .6 12 31 31 0 0 0 1 16.5a3 3 0 0 0 2.1 2.1C5 19 12 19 12 19s7 0 8.9-.4a3 3 0 0 0 2.1-2.1 31 31 0 0 0 .4-4.5 31 31 0 0 0-.4-4.5ZM9.8 15.2V8.8l5.4 3.2-5.4 3.2Z" />
    </svg>
  )
}
{
  name === 'twitter' && (
    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
      <path d="M18.9 2H22l-7 8 8.2 12h-6.4l-5-7.3L6 22H2.9l7.5-8.6L2.5 2H9l4.5 6.7L18.9 2Zm-1.1 18h1.8L7.3 3.9H5.4L17.8 20Z" />
    </svg>
  )
}
{
  name === 'instagram' && (
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="5" />
      <circle cx="12" cy="12" r="4" />
      <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
    </svg>
  )
}
{
  name === 'tiktok' && (
    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
      <path d="M16.5 3c.3 2.2 1.6 3.8 3.8 4v2.6c-1.3 0-2.6-.4-3.8-1.1v6.1a5.9 5.9 0 1 1-5.9-5.9c.3 0 .6 0 .9.1v2.7a3.2 3.2 0 1 0 2.3 3V3h2.7Z" />
    </svg>
  )
}
