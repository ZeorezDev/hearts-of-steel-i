---
/**
 * Genel amaçlı inline SVG ikon seti.
 * Özellik kartları, kurallar ve sayfa bölümlerinde kullanılır.
 * Tüm ikonlar `currentColor` kullanır; renk dışarıdan CSS ile verilir.
 */
interface Props {
  name: string;
  size?: number;
}
const { name, size = 26 } = Astro.props;
const s = size;
---

<svg
  viewBox="0 0 24 24"
  width={s}
  height={s}
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === 'mod' && (<><path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-4Z"/><path d="m9 12 2 2 4-4"/></>)}
  {name === 'map' && (<><path d="m9 4-6 2v14l6-2 6 2 6-2V4l-6 2-6-2Z"/><path d="M9 4v14M15 6v14"/></>)}
  {name === 'town' && (<><path d="M3 21h18M5 21V10l4-3 4 3v11M13 21v-7h6v7M9 13h0"/></>)}
  {name === 'diplomacy' && (<><path d="M12 3v18M5 7l7-4 7 4M5 7v6c0 2 3 3 3 3M19 7v6c0 2-3 3-3 3M5 7l3 6M19 7l-3 6"/></>)}
  {name === 'tank' && (<><path d="M3 16h16a2 2 0 0 0 2-2v-2H5a2 2 0 0 0-2 2v2Z"/><path d="M9 12V9h5l6-2M3 19h16"/><circle cx="7" cy="19" r="1"/><circle cx="12" cy="19" r="1"/><circle cx="17" cy="19" r="1"/></>)}
  {name === 'economy' && (<><path d="M3 3v18h18"/><path d="m7 14 3-4 3 3 5-7"/></>)}
  {name === 'staff' && (<><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3 3-5 6-5s6 2 6 5M16 7a3 3 0 0 1 0 6M21 20c0-2-1-3.5-3-4"/></>)}
  {name === 'roleplay' && (<><path d="M3 11a9 4 0 0 0 18 0M3 11a9 4 0 0 1 18 0M3 11v2a9 4 0 0 0 18 0v-2"/><path d="M12 7v8"/></>)}

  {name === 'general' && (<><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></>)}
  {name === 'war' && (<><path d="m14 6 6 6M5 19l3-3M19 5l-9 9M9 9 5 5H3v2l4 4M15 15l4 4h2v-2l-4-4"/></>)}
  {name === 'banned' && (<><circle cx="12" cy="12" r="9"/><path d="m5.5 5.5 13 13"/></>)}

  {name === 'shield' && (<><path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6l-8-4Z"/></>)}
  {name === 'plane' && (<><path d="M12 2c1 0 1.5 1 1.5 3v4l7 4v2l-7-2v4l2 1.5V24l-3.5-1L9 24v-2.5L11 20v-4l-7 2v-2l7-4V5c0-2 .5-3 1-3Z"/></>)}
  {name === 'flag' && (<><path d="M4 21V4M4 4h13l-2 4 2 4H4"/></>)}
  {name === 'compass' && (<><circle cx="12" cy="12" r="9"/><path d="m15 9-2 6-4 0 2-6 4 0Z"/></>)}
  {name === 'clock' && (<><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></>)}
  {name === 'book' && (<><path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2V5Z"/><path d="M19 19H6"/></>)}
  {name === 'github' && (<><path d="M9 19c-4 1.5-4-2-6-2m12 4v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1-.3-3.4 1.3a11.6 11.6 0 0 0-6 0C6.3 1.1 5.3 1.4 5.3 1.4a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 7.8c0 4.5 2.7 5.6 5.5 6-.4.4-.6.9-.5 1.6V21"/></>)}
  {name === 'arrow-right' && (<><path d="M5 12h14M13 6l6 6-6 6"/></>)}
  {name === 'arrow-left' && (<><path d="M19 12H5M11 6l-6 6 6 6"/></>)}
  {name === 'download' && (<><path d="M12 3v12m0 0 4-4m-4 4-4-4M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></>)}
  {name === 'search' && (<><circle cx="11" cy="11" r="7"/><path d="m21 21-4-4"/></>)}
  {name === 'youtube' && (<><rect x="2" y="5" width="20" height="14" rx="4"/><path d="m10 9 5 3-5 3V9Z"/></>)}
</svg>
