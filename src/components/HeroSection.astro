---
/**
 * Ana sayfa hero alanı.
 * Büyük başlık, alt başlık, açıklama, üç ana buton ve istatistik kartları.
 * Sunucu IP'si kopyalanabilir alan olarak gösterilir.
 */
import { siteConfig } from '../data/siteConfig';
import StatCard from './StatCard.astro';
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = (p: string) => `${base}${p}` || '/';

const stats = [
  { value: '1936', label: 'Avrupa' },
  { value: '50+', label: 'Mod' },
  { value: 'Towny', label: 'Ülke Sistemi' },
  { value: 'Diplomasi', label: 'İttifaklar' },
  { value: 'Tarihsel', label: 'Savaş' },
];
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-scan"></div>
  </div>

  <div class="container hero-inner">
    <span class="eyebrow reveal">1936 · Avrupa Cephesi</span>

    <h1 class="hero-title reveal">Hearts Of Steel <span class="num">I</span></h1>

    <p class="hero-sub reveal">
      2. Dünya Savaşı Temalı Modlu Minecraft Towny Sunucusu
    </p>

    <p class="hero-desc reveal">
      1936 Avrupa’sında ülkeni kur, ittifaklar yap, cepheleri yönet ve tarihin
      akışını Minecraft içinde yeniden yaz.
    </p>

    <div class="hero-actions reveal">
      <a href={siteConfig.discordUrl} class="btn btn--discord" target="_blank" rel="noopener">
        Discord'a Katıl
      </a>
      <a href={path('/join')} class="btn btn--gold">
        Sunucuya Nasıl Girilir?
      </a>
      <a href={path('/blog')} class="btn btn--ghost">
        Blog Yazılarını Oku
      </a>
    </div>

    <!-- Kopyalanabilir sunucu IP -->
    <div class="hero-ip reveal">
      <span class="hero-ip-label">Sunucu IP</span>
      <button class="hero-ip-btn" id="copyIpBtn" data-ip={siteConfig.serverIp} type="button">
        <code>{siteConfig.serverIp}</code>
        <span class="copy-state" id="copyState">Kopyala</span>
      </button>
    </div>

    <div class="hero-stats reveal">
      {stats.map((s) => <StatCard value={s.value} label={s.label} />)}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 11vw, 8rem);
    border-bottom: 1px solid var(--c-line);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  /* Harita/ızgara hissi */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 175, 55, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 175, 55, 0.06) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 35%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 35%, #000 30%, transparent 75%);
  }
  .hero-glow {
    position: absolute;
    top: -25%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.14), transparent 60%);
    filter: blur(20px);
  }
  /* Radar tarama çizgisi */
  .hero-scan {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(212, 175, 55, 0.05) 50%,
      transparent
    );
    background-size: 100% 8px;
    animation: scan 8s linear infinite;
    opacity: 0.5;
  }
  @keyframes scan {
    from { background-position: 0 -100%; }
    to { background-position: 0 200%; }
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-title {
    font-size: clamp(2.8rem, 9vw, 6rem);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 1.25rem;
    line-height: 0.95;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.6);
  }
  .hero-title .num {
    color: var(--c-gold);
    -webkit-text-stroke: 0;
    text-shadow: 0 0 30px rgba(212, 175, 55, 0.5);
  }

  .hero-sub {
    margin-top: 1.1rem;
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.4vw, 1.35rem);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--c-text);
  }
  .hero-desc {
    margin-top: 1rem;
    max-width: 56ch;
    color: var(--c-text-dim);
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .hero-ip {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }
  .hero-ip-label {
    font-size: 0.7rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--c-text-faint);
  }
  .hero-ip-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--surface-2);
    border: 1px dashed var(--c-line);
    border-radius: var(--radius);
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    transition: border-color var(--t-fast), background var(--t-fast);
  }
  .hero-ip-btn:hover {
    border-color: var(--c-gold);
    background: rgba(212, 175, 55, 0.06);
  }
  .hero-ip-btn code {
    color: var(--c-gold);
    font-size: 0.95rem;
  }
  .copy-state {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--c-text-faint);
    border-left: 1px solid var(--c-border);
    padding-left: 0.75rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 3rem;
    width: 100%;
    max-width: 820px;
  }
  @media (max-width: 720px) {
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const btn = document.getElementById('copyIpBtn');
  const state = document.getElementById('copyState');
  btn?.addEventListener('click', async () => {
    const ip = btn.getAttribute('data-ip') || '';
    try {
      await navigator.clipboard.writeText(ip);
      if (state) {
        const prev = state.textContent;
        state.textContent = 'Kopyalandı ✓';
        setTimeout(() => (state.textContent = prev), 1800);
      }
    } catch {
      /* pano erişimi yoksa sessizce geç */
    }
  });
</script>
